      <aliases enabled='yes' />
      <column caption='fatal' datatype='string' name='[Calculation_4983021898212196352]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [most_serious_injury] = &quot;Fatal&quot; Then &quot;Fatal&quot;&#10;ELSE &quot;Other&quot;&#10;&#10;END' />
      </column>
      <column caption='crash count text' datatype='string' name='[Calculation_4983021898466885633]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Crash Count&quot;' />
      </column>
      <column aggregation='Count' caption='month' datatype='integer' datatype-customized='true' name='[Calculation_6521986348949950464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='month([crash_date])' />
      </column>
      <column caption='Season' datatype='string' name='[Calculation_6521986348951334914]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([crash_date]) = 12 OR MONTH([crash_date]) = 1 OR MONTH([crash_date]) = 2 THEN &apos;Winter&apos;&#10;ELSEIF MONTH([crash_date]) = 3 OR MONTH([crash_date]) = 4 OR MONTH([crash_date]) = 5 THEN &apos;Spring&apos;&#10;ELSEIF MONTH([crash_date]) = 6 OR MONTH([crash_date]) = 7 OR MONTH([crash_date]) = 8 THEN &apos;Summer&apos;&#10;ELSEIF MONTH([crash_date]) = 9 OR MONTH([crash_date]) = 10 OR MONTH([crash_date]) = 11 THEN &apos;Fall&apos;&#10;END' />
      </column>
      <column caption='time of day' datatype='string' name='[Calculation_6521986348953399300]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, [crash_time]) &gt;= 5 AND DATEPART(&apos;hour&apos;, [crash_time]) &lt; 12 THEN &apos;Morning&apos;&#10;ELSEIF DATEPART(&apos;hour&apos;, [crash_time]) &gt;= 12 AND DATEPART(&apos;hour&apos;, [crash_time]) &lt; 17 THEN &apos;Afternoon&apos;&#10;ELSEIF DATEPART(&apos;hour&apos;, [crash_time]) &gt;= 17 AND DATEPART(&apos;hour&apos;, [crash_time]) &lt; 21 THEN &apos;Evening&apos;&#10;ELSE &apos;Night&apos;&#10;END' />
      </column>
      <column caption='select color by cf' datatype='string' name='[Calculation_83035123565010945]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='case [Parameters].[Parameter 1]&#10;&#10;when &quot;Injury Severity&quot; then [most_serious_injury]&#10;when &quot;Hit and Run&quot; then [hit_and_run]&#10;when &quot;Transportation Mode&quot; then [collision_type]&#10;when &quot;Season&quot; then [Calculation_6521986348951334914]&#10;when &quot;Time of Day&quot; then [Calculation_6521986348953399300]&#10;when &quot;Road Conditions&quot; then [road_conditions]&#10;when &quot;Traffic Controls&quot; then [traffic_controls]&#10;&#10;end' />
      </column>
      <column aggregation='Sum' caption='sheet swap' datatype='integer' name='[Calculation_83035123580354562]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='if [Parameters].[Parameter 1] = &quot;None&quot; then 0&#10;else 1&#10;&#10;end' />
      </column>
