    <worksheet name='crash-map'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='18'>Police Reported Ped, Cyclist, and Scooter Crashes: </run>
            <run fontcolor='#030f57' fontname='Tableau Semibold' fontsize='18'><![CDATA[<[federated.1vuy83u0sc2iee14ouon30my38bn].[none:year:nk]>]]></run>
            <run>Æ&#10;</run>
            <run fontsize='11' italic='true'>Each dots represents a crash reported to the Police; many more go unreported and do not appear on the map below. </run>
            <run>Æ&#10;</run>
            <run fontcolor='#030f57' fontname='Tableau Semibold' fontsize='11'>Use the filters to explore more</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='final-pvd-crashes' name='federated.1vuy83u0sc2iee14ouon30my38bn' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.1vuy83u0sc2iee14ouon30my38bn'>
            <column caption='fatal' datatype='string' name='[Calculation_4983021898212196352]' role='dimension' type='nominal'>
