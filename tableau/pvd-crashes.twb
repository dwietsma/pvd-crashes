        <calculation class='tableau' formula='case [Calculation_83035123565010945]&#10;&#10;// Enter fields we need to manually sort here&#10;&#10;// Season&#10;when &quot;Winter&quot; then 1&#10;when &quot;Spring&quot; then 2&#10;when &quot;Summer&quot; then 3&#10;when &quot;Fall&quot; then 4&#10;&#10;// Time of Day&#10;when &quot;Morning&quot; then 1&#10;when &quot;Afternoon&quot; then 2&#10;when &quot;Evening&quot; then 3&#10;when &quot;Night&quot; then 4&#10;&#10;// Injury Severity&#10;when &quot;No Injury&quot; then 6&#10;when &quot;Unknown&quot; then 5&#10;when &quot;Pain Reported&quot; then 4&#10;when &quot;Non-Incapacitating&quot; then 3&#10;when &quot;Incapacitating&quot; then 2&#10;when &quot;Fatal&quot; then 1&#10;&#10;end' />
